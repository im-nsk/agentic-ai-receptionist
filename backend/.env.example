# Copy to .env — never commit real secrets.
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
ENVIRONMENT=development

# Google: JSON key for the booking service account (used server-side only).
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","client_email":"..."}
#
# Optional override for GET /public/config (otherwise client_email is read from GOOGLE_CREDENTIALS_JSON).
# GOOGLE_SERVICE_ACCOUNT_EMAIL=ai-receptionist-service@project.iam.gserviceaccount.com
